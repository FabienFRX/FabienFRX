fn is_in_range(x, min, max) {
    if (x >= min) {
        if (x <= max) {
            return 1
        } else {
            return 0
        }
    } else {
        return 0
    }
}

fn classify_number(n) {
    if (n < 0) {
        return 0 - 1
    } else {
        if (n == 0) {
            return 0
        } else {
            return 1
        }
    }
}

fn main() {
    x = 15

    in_range = is_in_range(x, 10, 20)
    classification = classify_number(x)

    return in_range + classification
}
