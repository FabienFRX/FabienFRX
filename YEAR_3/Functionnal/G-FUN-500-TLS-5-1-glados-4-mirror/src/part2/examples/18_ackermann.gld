fn ackermann(m, n) {
    if (m == 0) {
        return n + 1
    } else {
        if (n == 0) {
            return ackermann(m - 1, 1)
        } else {
            inner = ackermann(m, n - 1)
            return ackermann(m - 1, inner)
        }
    }
}

fn main() {
    result = ackermann(3, 3)
    return result
}
