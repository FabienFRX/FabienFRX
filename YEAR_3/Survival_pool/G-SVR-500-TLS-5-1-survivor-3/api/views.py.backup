# Vues pour les images (proxies vers l'API JEB)
@api_view(['GET'])
def news_image(request, news_id):
    """Récupère l'image d'une actualité depuis l'API JEB"""
    try:
        from django.conf import settings
        import requests
        
        response = requests.get(
            f"{settings.JEB_API_BASE_URL}/news/{news_id}/image",
            headers={'X-Group-Authorization': settings.JEB_API_TOKEN}
        )
        
        if response.status_code == 200:
            return Response({'image_url': response.text.strip('"')})
        else:
            return Response({'error': 'Image not found'}, status=404)
    except Exception as e:
        return Response({'error': str(e)}, status=500)

