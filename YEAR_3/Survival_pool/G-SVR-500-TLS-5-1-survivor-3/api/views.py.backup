# Vue pour rechercher un utilisateur par email
@api_view(['GET'])
def user_by_email(request, email):
    """Récupère un utilisateur par email depuis l'API JEB"""
    try:
        from django.conf import settings
        import requests
        
        response = requests.get(
            f"{settings.JEB_API_BASE_URL}/users/email/{email}",
            headers={'X-Group-Authorization': settings.JEB_API_TOKEN}
        )
        
        if response.status_code == 200:
            return Response(response.json())
        else:
            return Response({'error': 'User not found'}, status=404)
    except Exception as e:
        return Response({'error': str(e)}, status=500)

# Vues pour les utilisateurs JEB
