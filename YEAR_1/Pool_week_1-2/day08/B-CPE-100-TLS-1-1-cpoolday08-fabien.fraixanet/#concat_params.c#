void my_putchar(char c)
{
    write(1, &c,1);
}

void my_putdigit(int n)
{
    my_putchar('0' + n);
}

int my_putstr(char const *str)
{
    int i = 0;

    while (str[i] != '\0') {
        my_putchar(str[i]);
        i = i +1;
    }
    return (0);
}
